# Claude Code ignore file
# Files and directories matching these patterns will be ignored by Claude Code

# Dependencies
node_modules/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Build outputs
.next/
out/
dist/
build/
*.egg-info/

# Cache and temporary files
storage/cache/
storage/uploads/
.cache/
*.log
*.tmp

# Database
*.db
*.sqlite
*.sqlite3

# Environment files (contain secrets)
.env
.env.local
.env.production

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore

# Test coverage
htmlcov/
.coverage
.pytest_cache/
coverage/

# Lock files (too large, no need to read)
uv.lock
package-lock.json
pnpm-lock.yaml
yarn.lock

# Compiled files
*.so
*.dylib
*.dll
*.exe

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Documentation build artifacts
docs/_build/
site/

# Large data files
*.pdf
*.tar.gz
*.zip
*.tgz

# Frontend build artifacts
.turbo/
.vercel/
.netlify/

# Electron
electron/dist/
electron/build/

# Alembic
alembic/versions/*.pyc

# macOS
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory
